<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" href="assets/images/icons/logohtl.png"/>
  
  <link href="assets/css/bootstrap.min.css" rel="stylesheet" />
  <link href="assets/css/bootstrap-extended.css" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/css/register.css">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

  <link href="assets/css/pace.min.css" rel="stylesheet" />

  <title>Register</title>
</head>

<body>

  <div class="container">

    <div class="left-side">
      <div class="brand">
        <h1 class="MyHtls" style="font-size: 86px;">MyHtls</h1>
        <h1>HOTEL NYAMAN</h1>
        <h5>Booking Your Stay Made Easy</h5>
        <h1 class="register-title" style="font-size: 100px;">REGISTER</h1>
      </div>
    </div>

    <div class="right-side">
      <div class="register-card">
        

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { id: "loginForm" }) do |f| %>
          
          <%# Menampilkan Pesan Error Devise %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="input-group">
            <%= f.label :username %>
            <%= f.text_field :username, autofocus: true, placeholder: "Enter username" %>
          </div>

          <div class="input-group">
            <%= f.label :email %>
            <%= f.email_field :email, autocomplete: "email", placeholder: "Enter email" %>
          </div>

          <div class="input-group">
            <%= f.label :no_telp %>
            <%= f.telephone_field :no_telp, autocomplete: "tel", placeholder: "Enter phone number" %>
          </div>

          <div class="input-group">
            <%= f.label :password %>
            <% if @minimum_password_length %>
              <small style="color: gray;">(<%= @minimum_password_length %> characters minimum)</small>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password", placeholder: "Enter password" %>
          </div>

          <div class="input-group">
            <%= f.label :password_confirmation, "Confirm Password" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Repeat password" %>
          </div>

          <%= f.button "Confirm", type: :submit, class: "actions" %>
        <% end %>
        <div class="footer-text">
          <p>Already registered? <%= render "devise/shared/links" %></p>
        </div>
      </div>
    </div>

  </div>

  <script src="assets/js/register.js"></script>
  <script src="assets/js/bootstrap.bundle.min.js"></script>

</body>
</html>