<% content_for :head do %>
  <link rel="icon" href="/assets/images/icons/logohtl.png" type="image/png" />
  <link href="/assets/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="/assets/css/home.css" rel="stylesheet">
<% end %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
  body { background-color: #f1f5f9; padding-top: 96px; }
  .hotel-navbar { background-color: rgba(15, 23, 42, 0.96) !important; }
  .page-title { color: #0f172a; font-weight: 800; letter-spacing: -0.02em; }
  .booking-card {
    transition: all 0.3s ease;
    border: none;
    border-radius: 1rem;
    background: #ffffff;
  }
  .booking-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
  }
  .status-badge {
    padding: 0.5rem 1rem;
    border-radius: 50rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }
  .status-pending { background-color: #fef9c3; color: #854d0e; }
  .status-paid { background-color: #fef3c7; color: #92400e; }
  .status-checked_in { background-color: #dbeafe; color: #1d4ed8; }
  .status-complete { background-color: #dcfce7; color: #166534; }
  .status-expired { background-color: #fee2e2; color: #991b1b; }

  .info-label { font-size: 0.7rem; color: #64748b; font-weight: 700; text-transform: uppercase; margin-bottom: 2px; }
  .info-value { font-weight: 600; color: #1e293b; }
</style>

<nav class="navbar navbar-expand-lg navbar-dark fixed-top hotel-navbar">
  <div class="container-fluid px-5">

    <!-- LEFT : LOGO -->
    <div class="navbar-left d-flex align-items-center gap-3">
      <a href="/home"><img src="/assets/images/icons/logohtl.png" class="hotel-logo"></a>
      <a href="/home" class="hotel-title MyHtls" style="text-decoration: none; color: #ce763c;">MyHtls</a>
    </div>

    <!-- TOGGLER -->
    <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- CENTER & RIGHT -->
    <div class="collapse navbar-collapse" id="navMenu">

      <!-- CENTER MENU -->
      <ul class="navbar-nav navbar-center position-absolute start-50 translate-middle-x gap-4">
        <li class="nav-item">
          <a class="nav-link" href="/home">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link active" href="/booking/">Riwayat Pesanan</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/booking/new">Pesan Sekarang</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="about.html">About</a>
        </li>
      </ul>

      <!-- RIGHT AUTH -->
      <ul class="navbar-nav ms-auto gap-3 navbar-auth">
  <% if user_signed_in? %>
    <li class="nav-item">
      <%= link_to "Profile", edit_user_registration_path, class: "nav-link" %>
    </li>
    <li class="nav-item">
      <%= button_to "Logout",
                    destroy_user_session_path,
                    method: :delete,
                    form: { data: { turbo: "false" } }, # Matikan turbo jika logout bermasalah
                    class: "btn btn-danger" %>
    </li>
  <% else %>
    <li class="nav-item">
      <%= link_to "Sign In", new_user_session_path, class: "nav-link" %>
    </li>
    <li class="nav-item">
      <%= link_to "Register", new_user_registration_path, class: "btn btn-primary register" %>
    </li>
  <% end %>
</ul>

    </div>
  </div>
</nav>

<div class="mb-4 pt-3 ps-2">
        <%= link_to :home, class: "btn btn-primary d-inline-flex align-items-center" do %>
          <i class="bi bi-chevron-left me-2"></i> KEMBALI
        <% end %>
      </div>
<div class="container py-5">
  <div class="d-flex align-items-center justify-content-between mb-5">
    <div>
      <h2 class="page-title mb-0">Riwayat Reservasi</h2>
      <p class="text-muted">Pantau status dan detail pesanan kamar Anda</p>
    </div>
    <a href="<%= new_booking_path %>" class="btn btn-primary rounded-pill px-4 shadow-sm">
      <i class="bi bi-plus-lg me-2"></i>Booking Baru
    </a>
  </div>

  <div class="row g-4">
    <% @bookings.each do |booking| %>
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card booking-card shadow-sm h-100">
          <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-start">
            <div>
              <div class="info-label">Kode Booking</div>
              <div class="h5 fw-bold text-primary mb-0">#<%= booking.booking_code %></div>
            </div>
            <span class="status-badge <%= "status-#{booking.status.downcase}" if booking.status.present? %>">
              <%= status_label(booking.status) %>
            </span>
            <% if booking.overdue_checkout? %>
              <span class="status-badge status-expired">Telat</span>
            <% end %>
          </div>

          <div class="card-body px-4">
            <div class="row g-3">
              <div class="col-6">
                <div class="info-label">Nomor Kamar</div>
                <div class="info-value"><i class="bi bi-door-closed me-1"></i><%= booking.room.room_number %></div>
              </div>
              <div class="col-6">
                <div class="info-label">Tipe</div>
                <div class="info-value text-truncate"><%= booking.room.room_level.name %></div>
              </div>
              <div class="col-12">
                <div class="info-label">Status Pembayaran</div>
                <div class="info-value text-dark text-capitalize"><%= status_label(booking.payment_status) %></div>
              </div>
              <div class="col-12">
                <div class="info-label">Harga per Malam</div>
                <div class="info-value text-dark fs-5">Rp <%= number_with_delimiter(booking.room.room_level.price) %></div>
              </div>
            </div>
          </div>

          <div class="card-footer bg-light bg-opacity-50 border-0 p-4 pt-0">
            <%= link_to booking_path(booking), class: "btn btn-outline-dark w-100 rounded-3 fw-bold mt-3 py-2" do %>
              Lihat Detail <i class="bi bi-arrow-right ms-1"></i>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
