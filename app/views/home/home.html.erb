<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <title>MyHtls – Hotel Premium</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" href="assets/images/icons/logohtl.png" type="image/png" />

  <!-- Bootstrap -->
  <link href="assets/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

  <!-- Font -->
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

  <!-- Custom CSS -->
  <link href="assets/css/home.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark fixed-top hotel-navbar">
  <div class="container-fluid px-5">

    <!-- LEFT : LOGO -->
    <div class="navbar-left d-flex align-items-center gap-3">
      <a href="home.html"><img src="assets/images/icons/logohtl.png" class="hotel-logo"></a>
      <a href="home.html" class="hotel-title MyHtls" style="text-decoration: none; color: #ce763c;">MyHtls</a>
    </div>

    <!-- TOGGLER -->
    <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- CENTER & RIGHT -->
    <div class="collapse navbar-collapse" id="navMenu">

      <!-- CENTER MENU -->
      <ul class="navbar-nav navbar-center position-absolute start-50 translate-middle-x gap-4">
        <li class="nav-item">
          <a class="nav-link active" href="home.html">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="about.html">About</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="privacy.html">Privacy Policy</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/booking/new">Pesan Sekarang</a>
        </li>
      </ul>

      <!-- RIGHT AUTH -->
      <ul class="navbar-nav ms-auto gap-3 navbar-auth">
  <% if user_signed_in? %>
    <li class="nav-item">
      <%= link_to "Profile", edit_user_registration_path, class: "nav-link" %>
    </li>
    <li class="nav-item">
      <%= button_to "Logout",
                    destroy_user_session_path,
                    method: :delete,
                    form: { data: { turbo: "false" } }, # Matikan turbo jika logout bermasalah
                    class: "btn btn-danger" %>
    </li>
  <% else %>
    <li class="nav-item">
      <%= link_to "Sign In", new_user_session_path, class: "nav-link" %>
    </li>
    <li class="nav-item">
      <%= link_to "Register", new_user_registration_path, class: "btn btn-primary register" %>
    </li>
  <% end %>
</ul>

    </div>
  </div>
</nav>

<!-- ================= HERO ================= -->
<section class="hero-section">
  <div class="hero-overlay"></div>

  <div class="container hero-content text-center text-white">
    <h1 class="brand-title MyHtls">MyHtls</h1>
    <p class="hero-subtitle">Hotel Dengan Pelayanan Terbaik</p>

    <!-- SEARCH BOX -->
    <div class="search-box-grid">

  <!-- DATE -->
  <div class="search-card" id="dateToggle">
    <small>Tanggal Menginap</small>
    <div class="search-value">
      <i class="bi bi-calendar-event"></i>
      <input type="text" id="dateInput" readonly placeholder="Pilih tanggal">
    </div>

    <div class="popup date-popup" id="datePopup"></div>
  </div>

  <!-- GUEST -->
  <div class="search-card" id="guestToggle">
    <small>Tamu & Kamar</small>
    <div class="search-value">
      <i class="bi bi-people"></i>
      <span id="guestValue">2 Dewasa, 0 Anak, 1 Kamar</span>
    </div>

    <div class="popup guest-popup" id="guestPopup">
    <div class="counter">
      <span>Dewasa</span>
      <div>
        <button class="minus" data-type="adult">−</button>
        <span id="adultCount">2</span>
        <button class="plus" data-type="adult">+</button>
      </div>
    </div>

    <div class="counter">
      <span>Anak</span>
      <div>
        <button class="minus" data-type="child">−</button>
        <span id="childCount">0</span>
        <button class="plus" data-type="child">+</button>
      </div>
    </div>

    <div class="counter">
      <span>Kamar</span>
      <div>
        <button class="minus" data-type="room">−</button>
        <span id="roomCount">1</span>
        <button class="plus" data-type="room">+</button>
      </div>
    </div>
  </div>
  </div>

  <!-- ROOM -->
  <div class="search-card" id="roomToggle">
    <small>Kelas Kamar</small>
    <div class="search-value">
      <i class="bi bi-door-open"></i>
      <span id="roomValue">Semua Kelas</span>
    </div>

    <div class="popup room-popup" id="roomPopup">
      <ul class="room-options">
        <li data-value="Semua Kelas">Semua Kelas</li>
        <li data-value="Kelas Bawah">Kelas Bawah</li>
        <li data-value="Kelas Menengah">Kelas Menengah</li>
        <li data-value="Kelas Atas">Kelas Atas</li>
      </ul>
    </div>
  </div>

  <button class="btn-booking">
    <i class="bi bi-search"></i>
    Cari 
  </button>
</div>

  </div>
</section>

<!-- ================= ROOM SECTION ================= -->
<section class="rooms">
  <h2 class="rooms-title">Our Best Bedrooms</h2>

  <div id="carouselExampleCaptions" class="carousel slide" data-bs-ride="carousel">

  <!-- indicators -->
  <div class="carousel-indicators">
    <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="0" class="active"></button>
    <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="1"></button>
    <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="2"></button>
  </div>

  <div class="carousel-inner">
    <div class="carousel-item active">
      <img src="https://picsum.photos/1200/500?1" class="d-block w-100">
      <div class="carousel-caption">
        <h5>First slide label</h5>
        <p>Nulla vitae elit libero.</p>
      </div>
    </div>

    <div class="carousel-item">
      <img src="https://picsum.photos/1200/500?2" class="d-block w-100">
      <div class="carousel-caption">
        <h5>Second slide label</h5>
        <p>Lorem ipsum dolor sit amet.</p>
      </div>
    </div>

    <div class="carousel-item">
      <img src="https://picsum.photos/1200/500?3" class="d-block w-100">
      <div class="carousel-caption">
        <h5>Third slide label</h5>
        <p>Praesent commodo cursus magna.</p>
      </div>
    </div>
  </div>

  <!-- controls -->
  <button class="carousel-control-prev" type="button"
          data-bs-target="#carouselExampleCaptions" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button"
          data-bs-target="#carouselExampleCaptions" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

</div>
</section>

<!-- ================= FOOTER ================= -->
<footer class="hotel-footer">
  <div class="container">
    <div class="row">

      <div class="col-md-4">
        <h5 style="font-family: Georgia, 'Times New Roman', Times, serif; font-weight: bold;">MyHtls</h5>
        <p>Hotel yang menyediakan kamar dengan pelayanan terbaik.</p>
      </div>

      <div class="col-md-4">
        <h5 class="footer-toggle" 
            data-bs-toggle="collapse" 
            data-bs-target="#footerTechnology"
            aria-expanded="false">
            Menggunakan
            <i class="bi bi-chevron-down ms-2"></i>
        </h5>

        <ul class="footer-list collapse" id="footerTechnology">
            <li>Bootsrap 5</li>
            <li>Javascript</li>
            <li>Ruby On Rails</li>
            <li>MySQL</li>
        </ul>
        </div>

      <div class="col-md-4">
        <h5 class="footer-toggle" 
            data-bs-toggle="collapse" 
            data-bs-target="#footerInfo"
            role="button"
            aria-expanded="false">
            Informasi
            <i class="bi bi-chevron-down ms-2"></i>
        </h5>

        <ul class="footer-list collapse" id="footerInfo">
            <li><a href="about.html">About Us</a></li>
            <li><a href="privacy.html">Privacy Policy</a></li>
            <li><a href="terms.html">Terms & Conditions</a></li>
        </ul>
        </div>


    </div>

    <hr>

    <p class="text-center mb-0">
      © 2026 Hotelucu. All rights reserved.
    </p>
  </div>
</footer>

<script src="assets/js/bootstrap.bundle.min.js"></script>
<script src="assets/js/home.js"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>


</body>
</html>

