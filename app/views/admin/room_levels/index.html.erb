<main class="page-content-body-card">
  <div class="card radius-10 mx-auto" style="max-width: 1100px;">
    <div class="card-body">

      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Manajemen Tingkatan Kamar</h5>

        <button class="btn btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#addRoomLevelModal">
          Tambah Tingkatan
        </button>
      </div>

      <hr>

      <div class="table-responsive">
        <table class="table table-bordered align-middle">
          <thead class="table-light">
            <tr>
              <th>Nama</th>
              <th>Harga</th>
              <th>Fasilitas</th>
              <th width="160">Aksi</th>
            </tr>
          </thead>

          <tbody>
            <% @room_levels.each do |room_level| %>
              <tr>
                <td><strong><%= room_level.name %></strong></td>
                <td>Rp <%= number_with_delimiter(room_level.price) %></td>
                <td>
                  <% if room_level.facilities.any? %>
                    <ul class="mb-0">
                      <% room_level.facilities.each do |facility| %>
                        <li><%= facility.name %></li>
                      <% end %>
                    </ul>
                  <% else %>
                    <span class="text-muted">-</span>
                  <% end %>
                </td>
                <td>
                  <button type="button"
                          class="btn btn-warning btn-sm"
                          data-bs-toggle="modal"
                          data-bs-target="#editRoomLevelModal-<%= room_level.id %>">
                    Edit
                  </button>

                  <%= link_to "Hapus",
                        admin_room_level_path(room_level),
                        method: :delete,
                        data: { confirm: "Hapus tingkatan ini?" },
                        class: "btn btn-danger btn-sm" %>
                </td>
              </tr>

            <% end %>
          </tbody>

        </table>
      </div>

    </div>
  </div>
</main>

<!-- MODAL TAMBAH TINGKATAN -->
<div class="modal fade" id="addRoomLevelModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Tambah Tingkatan Kamar</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <%= form_with model: [:admin, @room_level], local: true do |f| %>
        <div class="modal-body">

          <div class="mb-3">
            <%= f.label :name, "Nama Tingkatan" %>
            <%= f.text_field :name, class: "form-control", placeholder: "Contoh: Luxury" %>
          </div>

          <div class="mb-3">
            <%= f.label :price, "Harga" %>
            <%= f.number_field :price, class: "form-control" %>
          </div>

          
        </div>

        <div class="modal-footer">
          <button class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <%= f.submit "Simpan", class: "btn btn-success" %>
        </div>
      <% end %>

    </div>
  </div>
</div>

<% @room_levels.each do |room_level| %>
  <div class="modal fade" id="editRoomLevelModal-<%= room_level.id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Edit Tingkatan Kamar</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <%= form_with model: [:admin, room_level], local: true do |f| %>
          <div class="modal-body">
            <div class="mb-3">
              <%= f.label :name, "Nama Tingkatan", class: "form-label" %>
              <%= f.text_field :name, class: "form-control", placeholder: "Contoh: Luxury" %>
            </div>

            <div class="mb-3">
              <%= f.label :price, "Harga", class: "form-label" %>
              <%= f.number_field :price, class: "form-control" %>
            </div>

            <hr>
            <h6>Pilih Fasilitas</h6>
            <div class="row">
              <% Facility.all.each do |facility| %>
                <div class="col-6 mb-2">
                  <div class="form-check">
                    <%= check_box_tag "room_level[facility_ids][]",
                          facility.id,
                          room_level.facility_ids.include?(facility.id),
                          id: "edit_#{room_level.id}_fac_#{facility.id}",
                          class: "form-check-input" %>
                    <%= label_tag "edit_#{room_level.id}_fac_#{facility.id}", facility.name, class: "form-check-label" %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
            <%= f.submit "Update", class: "btn btn-success" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
