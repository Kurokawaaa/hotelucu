<main class="page-content-body-card">
  <div class="container-fluid">
    <div class="card radius-10 shadow-sm">
      <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
          <div>
            <h5 class="fw-bold mb-1">Riwayat Booking</h5>
            <p class="text-muted mb-0">Cari booking berdasarkan kode booking dan filter status.</p>
          </div>
          <span class="badge bg-primary"><%= @booking_histories.size %> Booking</span>
        </div>

        <%= form_with url: history_admin_bookings_path, method: :get, local: true, class: "row g-3 mb-4" do %>
          <div class="col-12 col-lg-6">
            <label class="form-label">Cari Kode Booking</label>
            <%= text_field_tag :code, @filter_code, class: "form-control", placeholder: "Contoh: BK-1700000000-AB12" %>
          </div>
          <div class="col-12 col-md-6 col-lg-3">
            <label class="form-label">Filter Status</label>
            <%= select_tag :status,
                  options_for_select([["Semua Status", ""]] + @history_status_options.map { |status| [status.titleize, status] }, @filter_status),
                  class: "form-select" %>
          </div>
          <div class="col-12 col-md-6 col-lg-3 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-primary w-100">Terapkan</button>
            <%= link_to "Reset", history_admin_bookings_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>

        <div class="table-responsive">
          <table class="table table-hover align-middle custom-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Kode Booking</th>
                <th>Username</th>
                <th>Email</th>
                <th>No Telpon</th>
                <th>Kamar</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Status</th>
                <th>Tanggal Pemesanan</th>
                <th class="text-center">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% @booking_histories.each do |booking| %>
                <tr>
                  <td>#<%= booking.id %></td>
                  <td class="fw-semibold text-primary"><%= booking.booking_code %></td>
                  <td><%= booking.user&.username.presence || "-" %></td>
                  <td><%= booking.user&.email.presence || "-" %></td>
                  <td><%= booking.user&.no_telp.presence || "-" %></td>
                  <td>
                    <div><strong><%= booking.room&.room_number || "-" %></strong></div>
                    <div class="small text-muted"><%= booking.room&.room_level&.name || "-" %></div>
                  </td>
                  <td><%= booking.check_in&.strftime("%d %b %Y") || "-" %></td>
                  <td><%= booking.check_out&.strftime("%d %b %Y") || "-" %></td>
                  <td>
                    <span class="badge <%= if booking.complete?
                                              "bg-success"
                                            elsif booking.checked_in?
                                              "bg-primary"
                                            elsif booking.expired?
                                              "bg-danger"
                                            else
                                              "bg-warning text-dark"
                                            end %>">
                      <%= status_label(booking.status) %>
                    </span>
                    <% if booking.overdue_checkout? %>
                      <span class="badge bg-danger ms-1">Telat</span>
                    <% end %>
                  </td>
                  <td><%= booking.created_at&.strftime("%d %b %Y") || "-" %></td>
                  <td class="text-center">
                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                      <button
                        type="button"
                        class="btn btn-sm btn-outline-primary btn-edit-booking"
                        data-update-url="<%= admin_booking_path(booking) %>"
                        data-id="<%= booking.id %>"
                        data-username="<%= booking.user&.username.to_s %>"
                        data-email="<%= booking.user&.email.to_s %>"
                        data-check-in="<%= booking.check_in&.to_s %>"
                        data-check-out="<%= booking.check_out&.to_s %>"
                        data-status="<%= booking.status %>">
                        Edit
                      </button>
                      <%= link_to "Detail", admin_booking_path(booking), class: "btn btn-sm btn-primary" %>
                      <%= button_to "Hapus",
                            admin_booking_path(booking),
                            method: :delete,
                            data: { turbo_confirm: "Yakin ingin menghapus booking ini?" },
                            class: "btn btn-sm btn-outline-danger" %>
                    </div>
                  </td>
                </tr>
              <% end %>

              <% if @booking_histories.empty? %>
                <tr>
                  <td colspan="10" class="text-center text-muted py-4">
                    Tidak ada data booking yang cocok dengan filter.
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="editBookingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Edit Booking</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <%= form_with url: "#", method: :patch, local: true, id: "editBookingForm" do %>
          <div class="modal-body">
            <div class="mb-2">
              <label class="form-label">ID Booking</label>
              <input type="text" class="form-control" id="editBookingId" readonly>
            </div>
            <div class="mb-2">
              <label class="form-label">Username</label>
              <input type="text" class="form-control" id="editBookingUsername" readonly>
            </div>
            <div class="mb-2">
              <label class="form-label">Email</label>
              <input type="text" class="form-control" id="editBookingEmail" readonly>
            </div>
            <div class="mb-2">
              <label class="form-label">Check-in</label>
              <input type="date" class="form-control" name="booking[check_in]" id="editBookingCheckIn" required>
            </div>
            <div class="mb-2">
              <label class="form-label">Check-out</label>
              <input type="date" class="form-control" name="booking[check_out]" id="editBookingCheckOut" required>
            </div>
            <div class="mb-2">
              <label class="form-label">Status</label>
              <select class="form-select" name="booking[status]" id="editBookingStatus" required>
                <option value="paid">paid</option>
                <option value="checked_in">Checked in</option>
                <option value="complete">complete</option>
                <option value="expired">expired</option>
              </select>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
            <button type="submit" class="btn btn-primary">Simpan</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</main>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const editModalElement = document.getElementById("editBookingModal");
    const editBookingForm = document.getElementById("editBookingForm");
    const editBookingId = document.getElementById("editBookingId");
    const editBookingUsername = document.getElementById("editBookingUsername");
    const editBookingEmail = document.getElementById("editBookingEmail");
    const editBookingCheckIn = document.getElementById("editBookingCheckIn");
    const editBookingCheckOut = document.getElementById("editBookingCheckOut");
    const editBookingStatus = document.getElementById("editBookingStatus");

    if (!editModalElement || !editBookingForm) return;

    const bookingModal = window.bootstrap ? bootstrap.Modal.getOrCreateInstance(editModalElement) : null;
    const editButtons = document.querySelectorAll(".btn-edit-booking");

    editButtons.forEach((button) => {
      button.addEventListener("click", function () {
        editBookingForm.action = this.dataset.updateUrl;
        editBookingId.value = this.dataset.id || "-";
        editBookingUsername.value = this.dataset.username || "-";
        editBookingEmail.value = this.dataset.email || "-";
        editBookingCheckIn.value = this.dataset.checkIn || "";
        editBookingCheckOut.value = this.dataset.checkOut || "";
        editBookingStatus.value = this.dataset.status || "paid";

        if (bookingModal) bookingModal.show();
      });
    });
  });
</script>
