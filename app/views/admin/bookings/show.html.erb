<main class="page-content-body-card">
  <div class="container-fluid">
    <div class="card radius-10">
      <div class="card-body">
        <h5 class="mb-3">Detail Booking</h5>
        <p>Kode: <strong><%= @booking.booking_code %></strong></p>
        <p>Pengguna: <strong><%= @booking.user.email %></strong></p>
        <p>Kamar: <strong><%= @booking.room.room_number %></strong></p>
        <p>Tingkatan: <strong><%= @booking.room.room_level.name %></strong></p>
        <p>Check In: <strong><%= @booking.check_in %></strong></p>
        <p>Check Out: <strong><%= @booking.check_out %></strong></p>
        <p>Status: <strong><%= @booking.status %></strong></p>

        <div class="mt-3">
          <%= link_to "Kembali", admin_bookings_path, class: "btn btn-secondary" %>
        </div>
      </div>
    </div>
  </div>
</main>
