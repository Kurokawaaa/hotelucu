<main class="page-content-body-card">
  <div class="container-fluid">
    <div class="card radius-10">
      <div class="card-body">
        <h5 class="mb-3">Detail Booking</h5>
        <p>Kode: <strong><%= @booking.booking_code %></strong></p>
        <p>Pengguna: <strong><%= @booking.user.email %></strong></p>
        <p>Kamar: <strong><%= @booking.room.room_number %></strong></p>
        <p>Tingkatan: <strong><%= @booking.room.room_level.name %></strong></p>
        <p>Check In: <strong><%= @booking.check_in %></strong></p>
        <p>Check Out: <strong><%= @booking.check_out %></strong></p>
        <p>Status: <strong><%= status_label(@booking.status) %></strong></p>
        <% if @booking.overdue_checkout? %>
          <div class="alert alert-danger py-2">Booking ini telat checkout.</div>
        <% end %>

        <div class="mt-3 d-flex gap-2">
          <%= link_to "Kembali", admin_bookings_path, class: "btn btn-secondary" %>
          <% if @booking.checked_in? %>
            <%= button_to "Checkout",
                  checkout_admin_booking_path(@booking),
                  method: :patch,
                  class: "btn btn-danger" %>
          <% end %>
          <%= button_to "Hapus Booking",
                admin_booking_path(@booking),
                method: :delete,
                data: { turbo_confirm: "Yakin ingin menghapus booking ini?" },
                class: "btn btn-outline-danger" %>
        </div>
      </div>
    </div>
  </div>
</main>
